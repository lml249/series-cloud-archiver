# Example only. Do not put real secrets in commits.

MP_BASE_URL=http://moviepilot.local:3001
MP_API_TOKEN=replace-with-local-token

MV3_BASE_URL=http://mediavault.local:7811
MV3_API_TOKEN=replace-with-local-token

EMBY_BASE_URL=http://emby.local:8096
EMBY_API_KEY=replace-with-local-token

QB_BASE_URL=http://qbittorrent.local:8080
QB_USERNAME=replace-with-local-username
QB_PASSWORD=replace-with-local-password

# Safety defaults
ARCHIVER_MODE=dry-run
MIN_SEED_DAYS=7
REQUIRE_MANUAL_APPROVAL_FOR_CLEANUP=true
ARCHIVER_MEDIA_ROOTS=/media/local-series
ARCHIVER_OUTPUT_FORMAT=markdown
ARCHIVER_TOP=100
ARCHIVER_INCLUDE_QB=true
ARCHIVER_INCLUDE_MP=true
ARCHIVER_INCLUDE_EMBY=false
ARCHIVER_PATH_ALIASES=/example/library-host=/example/qb-view
